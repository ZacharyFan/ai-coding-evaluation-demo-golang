            "command": "python \"$AI_EVAL_REPO/scripts/record_hook_event.py\" --adapter claude",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$AI_EVAL_REPO/scripts/record_hook_event.py\" --adapter claude",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$AI_EVAL_REPO/scripts/record_hook_event.py\" --adapter claude",
            "timeout": 30
          }
        ]
